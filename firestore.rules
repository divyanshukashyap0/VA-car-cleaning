rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Read user role from user document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'admin' || getUserData().role == 'super_admin');
    }

    function isEmployee() {
      return isAuthenticated() && (getUserData().role == 'staff' || getUserData().role == 'crew');
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
      
      // Saved Addresses Subcollection
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Multi-Device Push Notification Tokens
      match /devices/{deviceId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Bookings Collection
    match /bookings/{bookingId} {
      allow create: if true; // Public doorstep bookings
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.customerId == request.auth.uid ||
        resource.data.assignedEmployee == request.auth.uid ||
        resource.data.bookingStatus == 'Pending'
      );
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (resource.data.bookingStatus == 'Pending' && request.resource.data.assignedEmployee == request.auth.uid) ||
        (resource.data.assignedEmployee == request.auth.uid) ||
        (resource.data.customerId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }

    // Vehicles Collection
    match /vehicles/{vehicleId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
      allow update: if isAdmin() || (isAuthenticated() && resource.data.customerId == request.auth.uid && request.resource.data.customerId == resource.data.customerId);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
    }

    // Services Collection
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pricing Packages & Subscription Plans Collection
    match /pricing_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Employees / Crew Directory Collection
    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isOwner(employeeId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['availability', 'attendance', 'updatedAt']));
    }

    // Job Applications
    match /job_applications/{appId} {
      allow create: if true; // Public job applies
      allow read, write: if isAdmin();
    }

    // Payments Collection
    match /payments/{paymentId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Reviews Collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.customerId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stars', 'review', 'images', 'videos', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // Notifications Collection
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (
        resource.data.user == request.auth.uid ||
        resource.data.user == 'all_users' ||
        resource.data.user == 'system' ||
        isAdmin()
      );
      allow create: if true; // System & customer notifications
      allow update: if isAuthenticated() && (resource.data.user == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.user == request.auth.uid);
    }

    // Coupons Collection
    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Contact Messages
    match /contact_messages/{msgId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // Gallery
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // FAQs
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site Settings (About Us, Contact Details, Before/After config)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false; // Audit logs are immutable
    }
  }
}
